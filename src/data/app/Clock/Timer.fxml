<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600" prefWidth="300"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="data.app.Clock.TimerController"
            style="-fx-background-color:#111827; -fx-font-family:'Segoe UI';">
    <children>
        <VBox alignment="TOP_CENTER" spacing="20"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
              style="-fx-background-color:#111827;">
            <padding>
                <Insets top="15"/>
            </padding>
            <children>
                <Label text="Timer" style="-fx-text-fill:white; -fx-font-size:24px;">
                    <font>
                        <Font size="24"/>
                    </font>
                </Label>
                <Separator prefWidth="280" style="-fx-border-color:#374151;"/>

                <HBox alignment="CENTER" spacing="10">
                    <children>
                        <Spinner fx:id="spMinute" prefWidth="70"
                                 style="-fx-background-color:#1f2937; -fx-background-radius:10;"/>
                        <Label text=":" style="-fx-text-fill:white;"/>
                        <Spinner fx:id="spSecond" prefWidth="70"
                                 style="-fx-background-color:#1f2937; -fx-background-radius:10;"/>
                    </children>
                </HBox>

                <Label fx:id="lblTimer" text="00:00"
                       style="-fx-font-size:42px; -fx-font-weight:bold; -fx-text-fill:#00c8ff;">
                    <font>
                        <Font size="42"/>
                    </font>
                </Label>

                <HBox alignment="CENTER" spacing="15">
                    <children>
                        <Button text="Start" onAction="#startTimer"
                                style="-fx-background-color:#1f6feb; -fx-background-radius:15;
                                       -fx-text-fill:white; -fx-font-size:14px;
                                       -fx-font-weight:bold; -fx-cursor:hand;"/>
                        <Button text="Stop" onAction="#stopTimer"
                                style="-fx-background-color:#1f6feb; -fx-background-radius:15;
                                       -fx-text-fill:white; -fx-font-size:14px;
                                       -fx-font-weight:bold; -fx-cursor:hand;"/>
                        <Button text="Reset" onAction="#resetTimer"
                                style="-fx-background-color:#1f6feb; -fx-background-radius:15;
                                       -fx-text-fill:white; -fx-font-size:14px;
                                       -fx-font-weight:bold; -fx-cursor:hand;"/>
                    </children>
                </HBox>

                <Button text="← Back" onAction="#backHome"
                        style="-fx-background-color:#1f6feb; -fx-background-radius:15;
                               -fx-text-fill:white; -fx-font-size:14px;
                               -fx-font-weight:bold; -fx-cursor:hand;"/>
            </children>
        </VBox>
    </children>
</AnchorPane>