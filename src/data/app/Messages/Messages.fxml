<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600" prefWidth="300" style="-fx-background-color: #F7F8FA;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MessagesController">

    <top>
        <VBox alignment="CENTER" spacing="8" style="-fx-background-color: white;                      -fx-border-color: #E5E7EB;                      -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>

            <HBox alignment="CENTER" spacing="10">

                <ComboBox fx:id="contactComboBox" onAction="#selectContact" prefWidth="220" promptText="Select Contact" style="-fx-background-radius: 8;" />

                <Button onAction="#newContact" style="-fx-background-color: #2563EB;                                -fx-text-fill: white;                                -fx-font-weight: bold;                                -fx-background-radius: 8;" text="New" />
            </HBox>

            <Label fx:id="selectedContactLabel" style="-fx-font-size: 18px;                           -fx-font-weight: bold;                           -fx-text-fill: #1F2937;" text="Select Contact" />
        </VBox>
    </top>

    <center>
        <ScrollPane fx:id="messageTextArea" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent;                            -fx-background: transparent;">

            <content>
                <VBox fx:id="messageContainer" spacing="8">
                    <padding>
                        <Insets bottom="10" left="10" right="10" top="10" />
                    </padding>
                </VBox>
            </content>

        </ScrollPane>
    </center>

    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: white;                      -fx-border-color: #E5E7EB;                      -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>

            <Button fx:id="Send_Message" onAction="#openSendMessageWindow" style="-fx-background-color: #10B981;                            -fx-text-fill: white;                            -fx-font-size: 14px;                            -fx-font-weight: bold;                            -fx-background-radius: 20;                            -fx-padding: 8 20 8 20;" text="Send Message" />
        </HBox>
    </bottom>

</BorderPane>
