<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<HBox alignment="CENTER_RIGHT" prefWidth="270.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="data.app.Messages.chat_cell">

    <children>
      <Text fx:id="msg_time" strokeType="OUTSIDE" strokeWidth="0.0" textAlignment="CENTER">
         <HBox.margin>
            <Insets top="25.0" />
         </HBox.margin>
         <font>
            <Font size="8.0" />
         </font>
      </Text>
        <Label fx:id="msg_text" maxWidth="220" style="-fx-background-color: #34C759; -fx-background-radius: 15; -fx-padding: 8 12 8 12; -fx-text-fill: white;" text="hi," wrapText="true">
        <HBox.margin>
            <Insets bottom="5.0" right="15.0" top="5.0" />
        </HBox.margin></Label>
    </children>

</HBox>
